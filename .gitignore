# Mac OS
.DS_Store

# ignore all __pycache__/ directories
__pycache__/

# ignore all .pyc files
*.pyc

# virtual environment
# .venv로 시작하는 폴더 무시
.venv/ 
# venv로 시작하는 폴더 무시
venv/
# env로 시작하는 폴더 무시
env/

# environment variable -> 중요!!!!
# 이름이 정확히 .env인 파일을 무시
.env
# .env.로 시작하는 파일들 전부 무시
# 예) .env.local
.env.*
# 에외 처리 - 앞의 파일 중 .env.example만은 예외로 허용
!.env.example

# database
*.db
*.sqlite3
